	<RenderRules>
		<RenderInFront>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<SpriteRender name="granite_idle" offset="0,-5039" drawShadow="true" onState="Motion.Idle" />
			<SpriteRender name="granite_walk" offset="0,-5039" drawShadow="true" onState="Motion.Move" />
			<SpriteRender name="granite_jump" offset="0,-5039" drawShadow="true" onState="Motion.Jump" />
			<SpriteRender name="granite_jump" offset="0,-5039" drawShadow="true" onState="Motion.Fall" />
			<SpriteRender name="granite_punch" offset="0,-5039" drawShadow="true" onState="Motion.Punch" />
			
		</RenderInFront>
		<RenderShoes>
			<StopIf>
				<IsSitting>true</IsSitting>
				<IsSleepingOnaBed>true</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
	</RenderRules>
</ItemRenderer>